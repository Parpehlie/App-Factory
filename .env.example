# =============================================================================
# App Factory — environment template
# -----------------------------------------------------------------------------
# Copy this file to `.env` (git-ignored) and fill the values.
#
# IMPORTANT: every variable is prefixed with EXPO_PUBLIC_ and is therefore
# INLINED INTO THE CLIENT BUNDLE by Metro. Only publishable / non-secret keys
# belong here. RevenueCat SDK keys and the PostHog project API key are
# publishable by design — they are safe to ship. NEVER put a private/secret
# key (RevenueCat secret API key, server tokens, etc.) in this file.
# =============================================================================

# --- RevenueCat (publishable SDK keys, one per platform) ----------------------
# Dashboard > Project settings > API keys > "Public app-specific keys".
EXPO_PUBLIC_RC_IOS_API_KEY=appl_XXXXXXXXXXXXXXXXXXXXXXXX
EXPO_PUBLIC_RC_ANDROID_API_KEY=goog_XXXXXXXXXXXXXXXXXXXXXXXX
# The entitlement identifier that grants premium access (RevenueCat > Entitlements).
EXPO_PUBLIC_RC_ENTITLEMENT_ID=premium

# --- PostHog (EU cloud — GDPR-friendly hosting) -------------------------------
EXPO_PUBLIC_POSTHOG_API_KEY=phc_XXXXXXXXXXXXXXXXXXXXXXXX
EXPO_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# --- Region gate & monetization flags -----------------------------------------
# auto = detect from device locale | US | EU | OTHER
EXPO_PUBLIC_DEFAULT_REGION=auto
# Small Business Program enrolled? Drives 15% commission assumption in reporting.
EXPO_PUBLIC_SMALL_BUSINESS_PROGRAM=true
# Optionality-ready external web checkout. KEEP OFF. Stub only, no payment wired.
EXPO_PUBLIC_ENABLE_WEB_PURCHASE=false
EXPO_PUBLIC_WEB_PURCHASE_URL=

# --- Remote config / kill switch (placeholder) --------------------------------
# URL returning JSON: { "killSwitch": false, "message": "", "minSupportedVersion": "" }
EXPO_PUBLIC_REMOTE_CONFIG_URL=
