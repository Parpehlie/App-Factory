# Copy to `.env` in THIS app directory (Expo loads .env from the app root).
# Every value is EXPO_PUBLIC_* and inlined into the client bundle — publishable keys only.
# See the repo root .env.example for full documentation.

EXPO_PUBLIC_RC_IOS_API_KEY=appl_XXXXXXXXXXXXXXXXXXXXXXXX
EXPO_PUBLIC_RC_ANDROID_API_KEY=goog_XXXXXXXXXXXXXXXXXXXXXXXX
EXPO_PUBLIC_RC_ENTITLEMENT_ID=premium

EXPO_PUBLIC_POSTHOG_API_KEY=phc_XXXXXXXXXXXXXXXXXXXXXXXX
EXPO_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

EXPO_PUBLIC_DEFAULT_REGION=auto
EXPO_PUBLIC_SMALL_BUSINESS_PROGRAM=true
EXPO_PUBLIC_ENABLE_WEB_PURCHASE=false
EXPO_PUBLIC_WEB_PURCHASE_URL=

EXPO_PUBLIC_REMOTE_CONFIG_URL=

# Non-secret code shared only in store review instructions. Rotate after review if desired.
EXPO_PUBLIC_STORE_REVIEW_CODE=IH-STORE-XXXX
